# DeepSeek chat
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_FALLBACK_MODEL=deepseek-v4-flash
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_THINKING_TYPE=enabled

# ModelScope embeddings
MODELSCOPE_API_KEY=ms-your-key-here
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
MODELSCOPE_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# PDF parsing
PDF_PARSE_PROVIDER=auto
PDF_MIN_CJK_RATIO=0.2
PDF_MAX_REPLACEMENT_RATIO=0.01

# MinerU document parsing
MINERU_API_KEY=your-mineru-token-here
MINERU_SCRIPT_DIR=C:\Users\William\.claude\skills-backup\mineru-skill\scripts
MINERU_PYTHON=C:\Users\William\.claude\skills-backup\mineru-skill\scripts\.venv\Scripts\python.exe
MINERU_OUTPUT_DIR=./data/mineru
MINERU_MODEL=vlm
MINERU_MAX_PAGES=180
MINERU_MAX_FILE_MB=190
MINERU_TIMEOUT_SECONDS=1800

# Knowledge graph construction
KG_EXTRACT_CONCURRENCY=4
KG_MIN_SECTION_CHARS=120
KG_MAX_SECTION_INPUT_CHARS=6000
KG_MAX_CONCEPTS_PER_SECTION=8
KG_MAX_EDGES_PER_SECTION=12
KG_EXTRACTION_MAX_TOKENS=2048

# ChromaDB (leave unset for in-process persistent mode)
# CHROMA_HOST=chroma
# CHROMA_PORT=8000

# Data paths
DATA_ROOT=./data
# TEXTBOOKS_DIR=./data/textbooks

# App
LOG_LEVEL=INFO
